<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/img_app_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/app_info_title"
                android:src="@mipmap/ic_launcher" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_app_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_info_name"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_app_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_info_version_label"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_app_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineHeight="22sp"
            android:lineSpacingExtra="6dp"
            android:textColor="?attr/colorOnBackground"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_app_developer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="14sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"
            android:alpha="0.12"
            android:background="?attr/colorOnBackground" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_open_email"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@string/app_info_open_email"
                android:gravity="center"
                android:padding="0dp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="24dp"
                app:icon="@drawable/gmail_icon"
                app:iconGravity="textTop"
                app:iconPadding="0dp"
                app:iconSize="20dp"
                app:iconTint="@null"
                app:strokeColor="@color/ui_gray"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_open_github"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@string/app_info_open_github"
                android:gravity="center"
                android:padding="0dp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="24dp"
                app:icon="@drawable/linktree_icon"
                app:iconGravity="textTop"
                app:iconPadding="0dp"
                app:iconSize="20dp"
                app:iconTint="@null"
                app:strokeColor="@color/ui_gray"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_open_telegram"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@string/app_info_open_telegram"
                android:gravity="center"
                android:padding="0dp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="24dp"
                app:icon="@drawable/telegram_icon"
                app:iconGravity="textTop"
                app:iconPadding="0dp"
                app:iconSize="20dp"
                app:iconTint="@null"
                app:strokeColor="@color/ui_gray"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_open_github_profile"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/app_info_open_github_profile"
                android:gravity="center"
                android:padding="0dp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="24dp"
                app:icon="@drawable/github_icon"
                app:iconGravity="textTop"
                app:iconPadding="0dp"
                app:iconSize="20dp"
                app:iconTint="@null"
                app:strokeColor="@color/ui_gray"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_open_privacy"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="@string/app_info_privacy_policy"
            android:textAllCaps="false"
            android:textColor="@color/ui_gray"
            android:textSize="14sp"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="12dp"
            app:strokeColor="@color/ui_gray"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_open_coffee"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_info_open_coffee"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            app:backgroundTint="#4A4F5E"
            app:cornerRadius="12dp"
            app:icon="@drawable/buy_me_coffee_icon"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconSize="18dp"
            app:iconTint="@null" />
    </LinearLayout>
</ScrollView>
